  "description": "Outdoor and activity icon data for the Lucide icon ecosystem",
  "type": "module",
  "main": "dist/cjs/lucide-outdoors.js",
  "module": "dist/esm/lucide-outdoors.js",
  "types": "dist/lucide-outdoors.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/lucide-outdoors.js",
