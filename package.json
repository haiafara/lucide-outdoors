      "types": "./dist/lucide-outdoors.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "author": "Hai Afară! <hello@haiafara.ro>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/haiafara/lucide-outdoors.git"
  },
  "homepage": "https://github.com/haiafara/lucide-outdoors#readme",
  "bugs": {
    "url": "https://github.com/haiafara/lucide-outdoors/issues"
  },
  "keywords": [
    "lucide",
